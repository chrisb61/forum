generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  MEMBER
  TRUSTED_MEMBER
  MODERATOR
  ADMINISTRATOR
}

enum ThreadStatus {
  OPEN
  LOCKED
  ARCHIVED
  DELETED
}

enum ThreadType {
  STANDARD
  POLL
  QUESTION
  ANNOUNCEMENT
}

enum ReactionType {
  LIKE
  HELPFUL
  INSIGHTFUL
  FUNNY
}

enum NotificationType {
  THREAD_REPLY
  MENTION
  QUOTE
  DIRECT_MESSAGE
  MODERATOR_ACTION
  BADGE_AWARDED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  ABUSE
  HARASSMENT
  ILLEGAL_CONTENT
  OTHER
}

enum ModerationActionType {
  WARN
  MUTE
  SUSPEND
  BAN
  DELETE_CONTENT
  LOCK_THREAD
  MOVE_THREAD
  UNBAN
  UNMUTE
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  email             String    @unique
  passwordHash      String?
  displayName       String?
  avatar            String?
  bio               String?
  role              Role      @default(MEMBER)
  reputation        Int       @default(0)
  postCount         Int       @default(0)
  isEmailVerified   Boolean   @default(false)
  isSuspended       Boolean   @default(false)
  suspendedUntil    DateTime?
  isBanned          Boolean   @default(false)
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  oauthProvider   String?
  oauthProviderId String?

  threads       Thread[]
  posts         Post[]
  reactions     Reaction[]
  notifications Notification[]
  reports       Report[]         @relation("Reporter")
  moderationActions ModerationAction[] @relation("ModeratorActions")
  moderationTargets ModerationAction[] @relation("ModeratedUser")
  badges        UserBadge[]
  bookmarks     Bookmark[]
  threadSubscriptions ThreadSubscription[]
  sentMessages    DirectMessage[]  @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  blockedUsers  UserBlock[]      @relation("BlockingUser")
  blockedByUsers UserBlock[]     @relation("BlockedUser")
  pollVotes              PollVote[]
  postVersions           PostVersion[]
  professionalProfile    ProfessionalProfile?
  boardOpportunities     BoardOpportunity[]
  opportunityExpressions OpportunityExpression[]
  endorsementsGiven      Endorsement[]           @relation("EndorsementsGiven")
  endorsementsReceived   Endorsement[]           @relation("EndorsementsReceived")

  @@index([email])
  @@index([username])
  @@index([role])
}

model Category {
  id           String   @id @default(cuid())
  name         String
  description  String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  forums Forum[]
}

model Forum {
  id           String   @id @default(cuid())
  categoryId   String
  name         String
  description  String?
  slug         String   @unique
  displayOrder Int      @default(0)
  threadCount  Int      @default(0)
  postCount    Int      @default(0)
  isPrivate    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  threads  Thread[]

  @@index([categoryId])
  @@index([slug])
}

model Thread {
  id          String       @id @default(cuid())
  forumId     String
  authorId    String
  title       String
  slug        String       @unique
  status      ThreadStatus @default(OPEN)
  type        ThreadType   @default(STANDARD)
  isPinned    Boolean      @default(false)
  viewCount   Int          @default(0)
  replyCount  Int          @default(0)
  lastPostAt  DateTime?
  lastPostBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  forum       Forum      @relation(fields: [forumId], references: [id])
  author      User       @relation(fields: [authorId], references: [id])
  posts       Post[]
  tags        ThreadTag[]
  poll        Poll?
  bookmarks   Bookmark[]
  subscriptions ThreadSubscription[]

  @@index([forumId])
  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
}

model Post {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  isDeleted Boolean  @default(false)
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread    Thread       @relation(fields: [threadId], references: [id])
  author    User         @relation(fields: [authorId], references: [id])
  reactions Reaction[]
  reports   Report[]     @relation("PostReports")
  bookmarks Bookmark[]
  versions  PostVersion[]
  attachments Attachment[]

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model PostVersion {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@index([postId])
}

model Attachment {
  id        String   @id @default(cuid())
  postId    String
  filename  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])

  @@index([postId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId, type])
  @@index([postId])
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  color     String?
  createdAt DateTime    @default(now())

  threads ThreadTag[]

  @@index([slug])
}

model ThreadTag {
  threadId String
  tagId    String

  thread Thread @relation(fields: [threadId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([threadId, tagId])
}

model Poll {
  id           String    @id @default(cuid())
  threadId     String    @unique
  question     String
  isMultiChoice Boolean  @default(false)
  isAnonymous  Boolean   @default(false)
  endsAt       DateTime?
  createdAt    DateTime  @default(now())

  thread  Thread       @relation(fields: [threadId], references: [id])
  options PollOption[]
}

model PollOption {
  id      String @id @default(cuid())
  pollId  String
  text    String
  voteCount Int  @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id])
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String @id @default(cuid())
  optionId String
  userId   String

  option PollOption @relation(fields: [optionId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@unique([optionId, userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())

  reporter User  @relation("Reporter", fields: [reporterId], references: [id])
  post     Post? @relation("PostReports", fields: [targetId], references: [id], map: "report_post_fk")

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model ModerationAction {
  id          String               @id @default(cuid())
  moderatorId String
  targetUserId String?
  targetType  String?
  targetId    String?
  action      ModerationActionType
  reason      String
  duration    Int?
  createdAt   DateTime             @default(now())

  moderator  User  @relation("ModeratorActions", fields: [moderatorId], references: [id])
  targetUser User? @relation("ModeratedUser", fields: [targetUserId], references: [id])

  @@index([moderatorId])
  @@index([targetUserId])
  @@index([createdAt])
}

model Badge {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  icon        String?
  color       String?
  criteria    Json?
  createdAt   DateTime  @default(now())

  users UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  awardedBy String?

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@id([userId, badgeId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  threadId  String?
  postId    String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  thread Thread? @relation(fields: [threadId], references: [id])
  post   Post?   @relation(fields: [postId], references: [id])

  @@unique([userId, threadId])
  @@unique([userId, postId])
  @@index([userId])
}

model ThreadSubscription {
  userId    String
  threadId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  thread Thread @relation(fields: [threadId], references: [id])

  @@id([userId, threadId])
}

model DirectMessage {
  id           String    @id @default(cuid())
  senderId     String
  recipientId  String
  content      String
  isRead       Boolean   @default(false)
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
}

model UserBlock {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockingUser", fields: [blockerId], references: [id])
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}

model SiteSettings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model ProfessionalProfile {
  userId              String   @id
  headline            String?
  location            String?
  linkedIn            String?
  website             String?
  twitterX            String?
  professionalEmail   String?
  phone               String?
  availability        String?
  sectors             String[]
  expertiseAreas      String[]
  qualifications      String[]
  boardExperience     Json?
  // GDPR privacy controls
  showEmail           Boolean  @default(false)
  showPhone           Boolean  @default(false)
  showLinkedIn        Boolean  @default(true)
  profileVisibility   String   @default("members")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OpportunityType {
  NED
  CHAIR
  ADVISORY_BOARD
  COMMITTEE
  TRUSTEE
  FRACTIONAL_EXECUTIVE
  INVESTOR
  MENTOR
}

enum OpportunityStatus {
  OPEN
  CLOSED
  FILLED
}

model BoardOpportunity {
  id              String            @id @default(cuid())
  postedById      String
  title           String
  organisation    String
  type            OpportunityType
  status          OpportunityStatus @default(OPEN)
  description     String
  requirements    String?
  sectors         String[]
  location        String?
  remuneration    String?
  timeCommitment  String?
  closingDate     DateTime?
  isAnonymous     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  postedBy        User                      @relation(fields: [postedById], references: [id])
  expressions     OpportunityExpression[]

  @@index([postedById])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model OpportunityExpression {
  id            String   @id @default(cuid())
  opportunityId String
  userId        String
  message       String?
  createdAt     DateTime @default(now())

  opportunity   BoardOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@index([opportunityId])
  @@index([userId])
}

enum EndorsementSkill {
  GOVERNANCE
  STRATEGIC_THINKING
  LEADERSHIP
  ESG_KNOWLEDGE
  DIGITAL_EXPERTISE
  FINANCIAL_EXPERTISE
  RISK_MANAGEMENT
  STAKEHOLDER_ENGAGEMENT
  TRANSFORMATION
  INVESTOR_RELATIONS
}

model Endorsement {
  id          String           @id @default(cuid())
  endorserId  String
  endorseeId  String
  skill       EndorsementSkill
  comment     String?
  createdAt   DateTime         @default(now())

  endorser    User @relation("EndorsementsGiven", fields: [endorserId], references: [id])
  endorsee    User @relation("EndorsementsReceived", fields: [endorseeId], references: [id])

  @@unique([endorserId, endorseeId, skill])
  @@index([endorseeId])
  @@index([endorserId])
}
